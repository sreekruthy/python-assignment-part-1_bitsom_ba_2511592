    {
      "cell_type": "code",
      "source": [
        "#strip leading and trailing whitespace from essay and store this as clean_essay\n",
        "clean_essay = essay.strip()\n",
        "print(\"Stripped: \", clean_essay)\n",
        "\n",
        "#convert clean_essay to Title Case\n",
        "print(\"\\nTitle Case: \", clean_essay.title())\n",
        "\n",
        "#count how many times the word \"python\" appears in clean_essay\n",
        "count = clean_essay.count(\"python\")\n",
        "print(\"\\nCount of 'python':\", count)\n",
        "\n",
        "#replace every occurrence of \"python\" in clean_essay with \"Python 🐍\"\n",
        "replaced = clean_essay.replace(\"python\", \"Python 🐍\")\n",
        "print(\"\\nReplaced: \", replaced)\n",
        "\n",
        "#split clean_essay into individual sentences by splitting on \". \"\n",
        "sentences = clean_essay.split(\". \")\n",
        "print(\"\\nSentences List: \", sentences)\n",
        "\n",
        "#print each sentence on a new line, numbered starting from 1 and add a \".\" at the end of each sentence if it does not already end with one\n",
        "print(\"\\nNumbered Sentences:\")\n",
        "for i in range(len(sentences)):\n",
        "    sentence = sentences[i]\n",
        "\n",
        "    if not sentence.endswith(\".\"):\n",
        "        sentence += \".\"\n",
        "\n",
        "    print(f\"{i+1}. {sentence}\")"
      ],
